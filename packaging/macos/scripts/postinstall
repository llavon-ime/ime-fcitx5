#!/bin/sh
set -eu

PAYLOAD_ROOT="/Library/Application Support/llavon-ime/payload"

console_user="$(stat -f %Su /dev/console 2>/dev/null || true)"
if [ -z "${console_user}" ] || [ "${console_user}" = "root" ] || [ "${console_user}" = "loginwindow" ]; then
    console_user="${SUDO_USER:-}"
fi

if [ -z "${console_user}" ] || ! id "${console_user}" >/dev/null 2>&1; then
    echo "llavon-ime: no active user found; payload remains at ${PAYLOAD_ROOT}" >&2
    exit 0
fi

user_home="$(dscl . -read "/Users/${console_user}" NFSHomeDirectory 2>/dev/null | awk '{print $2}')"
if [ -z "${user_home}" ] || [ ! -d "${user_home}" ]; then
    user_home="$(eval echo "~${console_user}")"
fi

uid="$(id -u "${console_user}")"

stop_user_process() {
    process_name="$1"
    /usr/bin/pkill -x -u "${uid}" "${process_name}" >/dev/null 2>&1 || true
    attempts=0
    while /usr/bin/pgrep -x -u "${uid}" "${process_name}" >/dev/null 2>&1; do
        attempts=$((attempts + 1))
        if [ "${attempts}" -ge 20 ]; then
            /usr/bin/pkill -KILL -x -u "${uid}" "${process_name}" >/dev/null 2>&1 || true
            break
        fi
        /bin/sleep 0.1
    done
}

if [ ! -d "${PAYLOAD_ROOT}" ]; then
    echo "llavon-ime: missing package payload: ${PAYLOAD_ROOT}" >&2
    exit 1
fi

target_root="${user_home}/Library/fcitx5"

# The addon and service are loaded into the logged-in user's processes. Stop
# both before replacing their files so the restarted input method cannot retain
# an old service binary or addon image.
stop_user_process llavon-ime-service
stop_user_process Fcitx5

/bin/mkdir -p "${target_root}"
/usr/bin/ditto --norsrc --noextattr "${PAYLOAD_ROOT}" "${target_root}"

/usr/bin/find "${target_root}" "/Library/Application Support/llavon-ime" -name '._*' -delete

/usr/sbin/chown -R "${console_user}:staff" "${target_root}"
/bin/chmod -R a+rX "/Library/Application Support/llavon-ime/models" 2>/dev/null || true

if [ ! -d "/Library/Input Methods/Fcitx5.app" ]; then
    echo "llavon-ime: Fcitx5.app is not installed; install fcitx5-macos before using this input method." >&2
else
    /bin/launchctl asuser "${uid}" /usr/bin/open -gj -b org.fcitx.inputmethod.Fcitx5 >/dev/null 2>&1 || true
fi

exit 0
